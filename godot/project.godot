; splat-relight demo project (Godot 4.7). Forward+ required by GDGS.
config_version=5

[application]

config/name="splat-relight"
config/features=PackedStringArray("4.7", "Forward Plus")
run/main_scene="res://scenes/single_asset.tscn"

[editor_plugins]

enabled=PackedStringArray("res://addons/gdgs/plugin.cfg")

[rendering]

renderer/rendering_method="forward_plus"
