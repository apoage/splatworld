# --- Python ---
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/

# --- Data: raw inputs are user photogrammetry, NEVER commit (CLAUDE.md) ---
# Sample/source datasets: large; sample splats are CC0, pixel4 clips are raw footage — not published
datasets/
assets/raw/*
!assets/raw/.gitkeep

# Built assets are large; track metrics.json but not the heavy binaries/previews
assets/built/*/asset.ply
assets/built/*/preview/
assets/built/**/*.ply
# decompose's REFUSED-run metrics (fail-closed diagnostic, not a shipped artifact) — a refused
# run drops this next to built assets; tracked metrics_decompose.json stays the shipped pairing
metrics_decompose_refused.json
assets/built/**/metrics_decompose_refused.json
*.mp4
*.MP4
# exception: small committed demo clips (relight demo video, <10 MB)
!docs/media/*.mp4

# --- Godot ---
godot/.godot/
*.import
.import/
# eyeball screenshots from relight/tools/*.gd (default RELIGHT_SHOT_DIR)
godot/shots/

# --- smoke.sh scratch: all end-to-end health-check outputs land here, never in
# tracked assets/built (so a smoke run leaves the git tree clean) ---
.smoke/

# --- perf-budget sweep scratch: train_base/export budget-sweep outputs
# (run.py --out-root .perf/<budget>), never tracked assets/built ---
.perf/

# --- dark-factory runtime (config/queue/decisions ARE tracked; these are not) ---
.dark-factory/state.json
.dark-factory/run-*.jsonl
.dark-factory/verdicts/

# --- private reference scaffolding (license-restricted checkouts, e.g. GI-GS) — NEVER commit ---
scaffold/

# --- local Claude Code session state (settings/locks; never commit) ---
.claude/

# --- OS / editors ---
.DS_Store
*.swp

# local sample splats + built relight assets (heavy binaries, not tracked)
godot/gs_assets/*.ply
godot/gs_assets/*.relightply
# env-SH ambient sidecars mirrored next to gs_assets/*.relightply (derived, not tracked)
godot/gs_assets/*_env_sh.json
*.bak

# synthetic GT renders (large; regenerate via precompute/synthetic/make_plant.py)
assets/synthetic/
